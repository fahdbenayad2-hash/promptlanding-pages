// ── COUNTDOWN (localStorage, 4-hour) ──────────────
function initCountdown() {
  const KEY      = 'cod_v6_expiry';
  const DURATION = 4 * 60 * 60 * 1000;

  let expiry = parseInt(localStorage.getItem(KEY));
  if (!expiry || Date.now() > expiry) {
    expiry = Date.now() + DURATION;
    localStorage.setItem(KEY, String(expiry));
  }

  const pad = n => String(n).padStart(2, '0');

  function update() {
    const remaining = Math.max(0, expiry - Date.now());
    const h = Math.floor(remaining / 3600000);
    const m = Math.floor((remaining % 3600000) / 60000);
    const s = Math.floor((remaining % 60000) / 1000);

    [['cd-hours', h], ['cd-minutes', m], ['cd-seconds', s]].forEach(([id, val]) => {
      const el = document.getElementById(id);
      if (!el) return;
      const newVal = pad(val);
      if (el.textContent !== newVal) {
        el.style.animation = 'none';
        void el.offsetWidth;
        el.style.animation = 'digitFlip 0.6s var(--ease-out-expo)';
        el.textContent = newVal;
      }
    });

    if (remaining === 0) {
      localStorage.setItem(KEY, String(Date.now() + DURATION));
    }
  }

  update();
  setInterval(update, 1000);
}

// ── IMAGE GALLERY ──────────────────────────────────
function initImageGallery() {
  const mainImg = document.getElementById('hero-main-img');
  const thumbs  = document.querySelectorAll('.thumb-img');
  const galleryImgs = document.querySelectorAll('.gallery-img');
  const lightbox    = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const galleryArr = Array.from(galleryImgs);
  let currentLightboxIdx = 0;

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener('click', () => {
      if (!mainImg) return;
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = thumb.dataset.src || thumb.src;
        mainImg.style.opacity = '1';
      }, 150);
      mainImg.style.transition = 'opacity 0.25s ease';
      thumbs.forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
    });
  });

  galleryImgs.forEach((img, i) => {
    img.addEventListener('click', () => openLightbox(i));
    img.style.cursor = 'zoom-in';
  });

  function openLightbox(idx) {
    if (!lightbox || !lightboxImg) return;
    currentLightboxIdx = idx;
    lightboxImg.src = galleryArr[idx].dataset.src || galleryArr[idx].src;
    if (lightboxCounter) lightboxCounter.textContent = `${idx + 1} / ${galleryArr.length}`;
    lightbox.style.display = 'flex';
    lightbox.style.animation = 'lightboxIn 0.35s var(--ease-out-expo) forwards';
    lightboxImg.style.animation = 'lightboxImgIn 0.4s var(--ease-out-expo) 0.1s both';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });

  document.addEventListener('keydown', e => {
    if (!lightbox || lightbox.style.display === 'none') return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft')  openLightbox((currentLightboxIdx + 1) % galleryArr.length);
    if (e.key === 'ArrowRight') openLightbox((currentLightboxIdx - 1 + galleryArr.length) % galleryArr.length);
  });

  let touchStartX = 0;
  lightboxImg?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lightboxImg?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      openLightbox(dx < 0
        ? (currentLightboxIdx + 1) % galleryArr.length
        : (currentLightboxIdx - 1 + galleryArr.length) % galleryArr.length);
    }
  });
}

