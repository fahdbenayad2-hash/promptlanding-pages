## B. Cinematic Number Counter

```javascript
const easeOutExpo = t => t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
const animateNumber = (el, target, duration = 1800, suffix = '', prefix = '') => {
  const start = performance.now();
  const startVal = 0;
  const formatter = new Intl.NumberFormat('ar-DZ');
  const tick = now => {
    const t = Math.min(1, (now - start) / duration);
    const val = Math.floor(startVal + (target - startVal) * easeOutExpo(t));
    el.textContent = prefix + formatter.format(val) + suffix;
    if (t < 1) requestAnimationFrame(tick);
    else el.textContent = prefix + formatter.format(target) + suffix;
  };
  requestAnimationFrame(tick);
};

const initCounters = () => {
  const counters = document.querySelectorAll('.counter[data-target]');
  if (!counters.length) return;
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target;
        animateNumber(el, parseInt(el.dataset.target), 1800,
                     el.dataset.suffix || '', el.dataset.prefix || '');
        io.unobserve(el);
      }
    });
  }, { threshold: 0.3 });
  counters.forEach(c => io.observe(c));
};
```

## C. Flip Countdown Timer (localStorage-backed)

```javascript
const initCountdown = () => {
  const el = document.querySelector('[data-countdown]');
  if (!el) return;
  const STORAGE_KEY = 'lp_countdown_end';
  let endTime = parseInt(localStorage.getItem(STORAGE_KEY) || '0');
  const HOURS = 24;
  if (!endTime || endTime < Date.now()) {
    endTime = Date.now() + HOURS * 60 * 60 * 1000;
    localStorage.setItem(STORAGE_KEY, endTime);
  }
  const cells = el.querySelectorAll('.flip-cell');
  const pad = n => String(n).padStart(2, '0');
  const update = () => {
    const remaining = Math.max(0, endTime - Date.now());
    const h = Math.floor(remaining / 3.6e6);
    const m = Math.floor((remaining % 3.6e6) / 6e4);
    const s = Math.floor((remaining % 6e4) / 1e3);
    [h, m, s].forEach((v, i) => {
      const cell = cells[i];
      const newText = pad(v);
      if (cell.textContent !== newText) {
        cell.textContent = newText;
        cell.classList.add('flip');
        setTimeout(() => cell.classList.remove('flip'), 400);
      }
    });
  };
  update();
  setInterval(update, 1000);
};
