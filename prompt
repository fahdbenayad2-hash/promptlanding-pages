const initReveals = () => {
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.reveal-fade, .reveal-scale, .reveal-blur, .reveal-mask, .reveal-side, .reveal-text, .reveal-stagger')
