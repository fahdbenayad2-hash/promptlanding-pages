function initFormValidation() {
  const rules = [
    { id: 'field_name',    validate: v => v.trim().length >= 3,                   msg: 'الرجاء إدخال الاسم الكامل (3 أحرف على الأقل)' },
    { id: 'field_phone',   validate: v => /^0[5-7][0-9]{8}$/.test(v.trim()),     msg: 'رقم الهاتف غير صحيح — مثال: 0555123456' },
    { id: 'field_wilaya',  validate: v => v !== '',                                msg: 'الرجاء اختيار الولاية' },
    { id: 'field_commune', validate: v => v !== '',                                msg: 'الرجاء اختيار البلدية' },
    { id: 'field_address', validate: v => v.trim().length >= 10,                  msg: 'الرجاء إدخال العنوان بالتفصيل (10 أحرف على الأقل)' },
  ];

  rules.forEach(({ id, validate, msg }) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('blur', () => {
      const err = document.getElementById(`${id}-error`);
      if (!validate(el.value)) {
        el.classList.add('field-error');
        if (err) { err.textContent = msg; err.style.display = 'block'; }
      } else {
        el.classList.remove('field-error');
        if (err) err.style.display = 'none';
      }
    });
  });
}

function validateForm() {
  const rules = [
    { id: 'field_name',    validate: v => v.trim().length >= 3,               msg: 'الرجاء إدخال الاسم الكامل' },
    { id: 'field_phone',   validate: v => /^0[5-7][0-9]{8}$/.test(v.trim()), msg: 'رقم الهاتف غير صحيح' },
    { id: 'field_wilaya',  validate: v => v !== '',                            msg: 'الرجاء اختيار الولاية' },
    { id: 'field_commune', validate: v => v !== '',                            msg: 'الرجاء اختيار البلدية' },
    { id: 'field_address', validate: v => v.trim().length >= 10,              msg: 'الرجاء إدخال العنوان بالتفصيل' },
  ];
  let valid = true;
  rules.forEach(({ id, validate, msg }) => {
    const el  = document.getElementById(id);
    const err = document.getElementById(`${id}-error`);
    if (!el) return;
    if (!validate(el.value)) {
      valid = false;
      el.classList.add('field-error');
      if (err) { err.textContent = msg; err.style.display = 'block'; }
      if (valid === false) el.focus(); // focus first error
    }
  });
  return valid;
}

// ─────────────────────────────────────────
// FORM SUBMIT — with timeout + retry
// ─────────────────────────────────────────
async function handleFormSubmit(e) {
  e.preventDefault();

  // 1. Honeypot
  if (document.getElementById('hp_w')?.value !== '') {
    showFakeSuccess();
    return;
  }

  // 2. Selection validation
  if (!selectedColor) {
    shakeElement('color-selector');
    document.getElementById('color-selector')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  if (!selectedSize) {
    shakeElement('size-selector');
    document.getElementById('size-selector')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  // 3. Field validation
  if (!validateForm()) return;

  // 4. Build payload
  const getVal = id => document.getElementById(id)?.value || '';
  const getOptText = id => {
    const sel = document.getElementById(id);
    return sel?.options[sel.selectedIndex]?.text || '';
  };

  const payload = {
    name:         getVal('field_name').trim(),
    phone:        getVal('field_phone').trim(),
    wilaya:       getOptText('field_wilaya'),
    commune:      getOptText('field_commune'),
    address:      getVal('field_address').trim(),
    notes:        getVal('field_notes').trim(),
    product:      PRODUCT_NAME,
    color:        selectedColor,
    size:         selectedSize,
    price:        PRODUCT_PRICE,
    utm_source:   UTM.source,
    utm_medium:   UTM.medium,
    utm_campaign: UTM.campaign,
    utm_content:  UTM.content,
    utm_term:     UTM.term,
    page_url:     window.location.href,
    timestamp:    new Date().toISOString()
  };

  // 5. Send with timeout
  setButtonState('loading');

  const controller = new AbortController();
  const timeoutId  = setTimeout(() => controller.abort(), 8000);

  try {
    await fetch(GAS_URL, {
      method:  'POST',
      mode:    'no-cors', // ⚠️ Opaque response — fetch resolve = treat as success
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload),
      signal:  controller.signal
    });
    clearTimeout(timeoutId);
    onOrderSuccess();

  } catch (err) {
    clearTimeout(timeoutId);
    if (err.name === 'AbortError') {
      setButtonState('timeout');
    } else if (!formSubmitRetried) {
      formSubmitRetried = true;
      setButtonState('loading');
      setTimeout(() => handleFormSubmit(e), 3000); // one auto-retry
    } else {
      setButtonState('error');
    }
  }
}

function onOrderSuccess() {
  setButtonState('success');
  triggerConfetti();

  const msg = document.getElementById('success-message');
  if (msg) msg.style.display = 'block';

  // Disable form to prevent double submit
  document.getElementById('order-form-element')
    ?.querySelectorAll('input,select,textarea,button')
    .forEach(el => el.disabled = true);

  // Pixel Lead event
  if (PIXEL_ID) {
    fbq('track', 'Lead', {
      value:    parseFloat(PRODUCT_PRICE),
      currency: 'DZD',
      content_name: PRODUCT_NAME
    });
  }

  // Scroll to success message
  msg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function showFakeSuccess() {
  // Bot submitted — show success without sending
  setButtonState('success');
  triggerConfetti();
}

function setButtonState(state) {
  const btn = document.getElementById('submit-btn');
  if (!btn) return;
  const states = {
    loading: { text: '⏳ جاري الإرسال...', disabled: true,  cls: 'btn-loading' },
    success: { text: '✅ تم استلام طلبك!', disabled: true,  cls: 'btn-success' },
    timeout: { text: '⚠️ انتهت المهلة — أعيدي المحاولة',  disabled: false, cls: 'btn-error' },
    error:   { text: '❌ حدث خطأ، أعيدي المحاولة',         disabled: false, cls: 'btn-error' },
    default: { text: '✅ تأكيد الطلب',     disabled: false, cls: '' }
  };
  const s = states[state] || states.default;
  btn.textContent = s.text;
  btn.disabled    = s.disabled;
  btn.className   = 'cta-button submit-btn ' + s.cls;
}

