function initFormValidation() {
  const rules = [
    { id: 'field_name',    validate: v => v.trim().length >= 3,                   msg: 'الرجاء إدخال الاسم الكامل (3 أحرف على الأقل)' },
    { id: 'field_phone',   validate: v => /^0[5-7][0-9]{8}$/.test(v.trim()),     msg: 'رقم الهاتف غير صحيح — مثال: 0555123456' },
    { id: 'field_wilaya',  validate: v => v !== '',                                msg: 'الرجاء اختيار الولاية' },
    { id: 'field_commune', validate: v => v !== '',                                msg: 'الرجاء اختيار البلدية' },
    { id: 'field_address', validate: v => v.trim().length >= 10,                  msg: 'الرجاء إدخال العنوان بالتفصيل (10 أحرف على الأقل)' },
  ];

  rules.forEach(({ id, validate, msg }) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('blur', () => {
      const err = document.getElementById(`${id}-error`);
      if (!validate(el.value)) {
        el.classList.add('field-error');
        if (err) { err.textContent = msg; err.style.display = 'block'; }
      } else {
        el.classList.remove('field-error');
        if (err) err.style.display = 'none';
      }
    });
  });
}

function validateForm() {
  const rules = [
    { id: 'field_name',    validate: v => v.trim().length >= 3,               msg: 'الرجاء إدخال الاسم الكامل' },
    { id: 'field_phone',   validate: v => /^0[5-7][0-9]{8}$/.test(v.trim()), msg: 'رقم الهاتف غير صحيح' },
    { id: 'field_wilaya',  validate: v => v !== '',                            msg: 'الرجاء اختيار الولاية' },
    { id: 'field_commune', validate: v => v !== '',                            msg: 'الرجاء اختيار البلدية' },
    { id: 'field_address', validate: v => v.trim().length >= 10,              msg: 'الرجاء إدخال العنوان بالتفصيل' },
  ];
  let valid = true;
  rules.forEach(({ id, validate, msg }) => {
    const el  = document.getElementById(id);
    const err = document.getElementById(`${id}-error`);
    if (!el) return;
    if (!validate(el.value)) {
      valid = false;
      el.classList.add('field-error');
      if (err) { err.textContent = msg; err.style.display = 'block'; }
    }
  });
  return valid;
}

// ── FORM SUBMIT ────────────────────────────────────
async function handleFormSubmit(e) {
  e.preventDefault();

  // 1. Honeypot
  if (document.getElementById('hp_w')?.value !== '') {
    showFakeSuccess();
    return;
  }

  // 2. Selection validation
  if (!selectedColor) {
    shakeElement('color-selector');
    document.getElementById('color-selector')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  if (!selectedSize) {
    shakeElement('size-selector');
    document.getElementById('size-selector')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  // 3. Field validation
  if (!validateForm()) return;

  // 4. Build payload
  const bundle = BUNDLE_DATA[selectedBundleIdx];
  const getVal = id => document.getElementById(id)?.value || '';
  const getOptText = id => {
    const sel = document.getElementById(id);
    return sel?.options[sel.selectedIndex]?.text || '';
  };

  const payload = {
    name:           getVal('field_name').trim(),
    phone:          getVal('field_phone').trim(),
    wilaya:         getOptText('field_wilaya'),
    commune:        getOptText('field_commune'),
    address:        getVal('field_address').trim(),
    notes:          getVal('field_notes').trim(),
    product:        PRODUCT_NAME,
    color:          selectedColor,
    size:           selectedSize,
    bundle_label:   formatBundleLabel(bundle.qty),
    bundle_qty:     bundle.qty * quantity,
    unit_price:     bundle.price,
    total_price:    String(parseInt(bundle.price) * quantity),
    delivery_type:  deliveryType,
    utm_source:     UTM.source,
    utm_medium:     UTM.medium,
    utm_campaign:   UTM.campaign,
    utm_content:    UTM.content,
    utm_term:       UTM.term,
    page_url:       window.location.href,
    timestamp:      new Date().toISOString()
  };

  // 5. Send
  setButtonState('loading');

  const controller = new AbortController();
  const timeoutId  = setTimeout(() => controller.abort(), 8000);

  try {
    await fetch(GAS_URL, {
      method:  'POST',
      mode:    'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload),
      signal:  controller.signal
    });
    clearTimeout(timeoutId);
    onOrderSuccess();

  } catch (err) {
    clearTimeout(timeoutId);
    if (err.name === 'AbortError') {
      setButtonState('timeout');
    } else if (!formSubmitRetried) {
      formSubmitRetried = true;
      setButtonState('loading');
      setTimeout(() => handleFormSubmit(e), 3000);
    } else {
      setButtonState('error');
    }
  }
}

function onOrderSuccess() {
  setButtonState('success');
  triggerConfetti();

  const msg = document.getElementById('success-message');
  if (msg) {
    msg.style.display = 'block';
    msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  document.getElementById('order-form-element')
    ?.querySelectorAll('input,select,textarea,button')
    .forEach(el => el.disabled = true);

  if (PIXEL_ID) {
    fbq('track', 'Lead', {
      value:    parseFloat(BUNDLE_DATA[selectedBundleIdx].price) * quantity,
      currency: 'DZD',
      content_name: PRODUCT_NAME
    });
  }
}

function showFakeSuccess() {
  setButtonState('success');
  triggerConfetti();
}

function setButtonState(state) {
  const btn = document.getElementById('submit-btn');
  if (!btn) return;
  const bundle = BUNDLE_DATA[selectedBundleIdx];
  const total  = bundle ? parseInt(bundle.price) * quantity : 0;

  const states = {
    loading: { html: '⏳ جاري الإرسال...',                disabled: true,  cls: 'btn-loading' },
    success: { html: '✅ تم استلام طلبك!',                 disabled: true,  cls: 'btn-success' },
    timeout: { html: '⚠️ انتهت المهلة — أعيدي المحاولة',   disabled: false, cls: 'btn-error' },
    error:   { html: '❌ حدث خطأ، أعيدي المحاولة',         disabled: false, cls: 'btn-error' },
    default: { html: `أكّدي الطلب — <span class="btn-total">${formatPrice(String(total))} دج</span>`, disabled: false, cls: '' }
  };
  const s = states[state] || states.default;
  btn.innerHTML   = s.html;
  btn.disabled    = s.disabled;
  btn.className   = 'cta-button submit-btn ' + s.cls;
  btn.dataset.state = state;
}

// ── CONFETTI ───────────────────────────────────────
function triggerConfetti() {
  const colors = [
    getComputedStyle(document.documentElement).getPropertyValue('--color-primary').trim(),
    getComputedStyle(document.documentElement).getPropertyValue('--color-gold').trim(),
    getComputedStyle(document.documentElement).getPropertyValue('--color-secondary').trim(),
  ];
  for (let i = 0; i < 24; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random() * 100 + 'vw';
    piece.style.top  = '-10px';
    piece.style.background = colors[i % colors.length];
    piece.style.animationDuration = (2 + Math.random() * 2) + 's';
    piece.style.animationDelay   = (Math.random() * 0.5) + 's';
    if (i % 3 === 0)  { piece.style.width = '6px';  piece.style.height = '12px'; }
    if (i % 4 === 0)  { piece.style.borderRadius = '50%'; piece.style.width = '10px'; piece.style.height = '10px'; }
    document.body.appendChild(piece);
    setTimeout(() => piece.remove(), 4000);
  }
}

// ── FLOATING PARTICLES ─────────────────────────────
function initFloatingParticles() {
  const hero = document.getElementById('hero-section');
  if (!hero) return;
  for (let i = 0; i < 6; i++) {
    const p = document.createElement('div');
    p.className = 'floating-particle';
    p.style.left   = Math.random() * 100 + '%';
    p.style.top    = Math.random() * 100 + '%';
    p.style.animationDelay    = (Math.random() * 4) + 's';
    p.style.animationDuration = (6 + Math.random() * 4) + 's';
    hero.appendChild(p);
  }
}

// ── ANIMATED COUNTERS ──────────────────────────────
function initAnimatedCounters() {
  const counters = document.querySelectorAll('[data-count]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el     = entry.target;
      const target = parseInt(el.dataset.count);
      const suffix = el.dataset.suffix || '';
      let start = 0;
      const step = target / 50;
      const timer = setInterval(() => {
        start = Math.min(start + step, target);
        el.textContent = Math.floor(start).toLocaleString('ar-DZ') + suffix;
        if (start >= target) clearInterval(timer);
      }, 30);
      observer.unobserve(el);
    });
  }, { threshold: 0.5 });
  counters.forEach(el => observer.observe(el));
}

// ── UTILITIES ──────────────────────────────────────
function shakeElement(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.remove('selector-error');
  void el.offsetWidth;
  el.classList.add('selector-error');
  el.addEventListener('animationend', () => el.classList.remove('selector-error'), { once: true });
}
